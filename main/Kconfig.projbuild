menu "Asisten Xiaozhi"

config OTA_URL
    string "URL OTA Default"
    default "https://api.tenclass.net/xiaozhi/ota/"
    help
        Aplikasi akan mengakses URL ini untuk memeriksa firmware baru dan alamat server.

menu "Campus RAG"

config CAMPUS_RAG_ENABLE
    bool "Aktifkan Campus RAG Server eksternal"
    default y
    help
        Jika URL server diisi, self.campus.query akan mencoba server RAG lebih dulu.
        Jika server tidak tersedia, firmware otomatis kembali ke data kampus lokal.

config CAMPUS_RAG_SERVER_URL
    string "URL Campus RAG Server"
    default ""
    help
        Contoh: http://192.168.1.10:8787
        Kosongkan untuk memakai fallback data kampus lokal saja.

config CAMPUS_RAG_TIMEOUT_MS
    int "Timeout Campus RAG Server dalam milidetik"
    default 1800
    range 500 8000
    help
        Timeout pendek menjaga jawaban tetap cepat jika server eksternal mati.

endmenu

choice
    prompt "Aset Flash"
    default FLASH_DEFAULT_ASSETS if !USE_EMOTE_MESSAGE_STYLE
    default FLASH_EXPRESSION_ASSETS if USE_EMOTE_MESSAGE_STYLE
    help
        Pilih aset yang akan di-flash.

    config FLASH_NONE_ASSETS
        bool "Jangan flash aset"
    config FLASH_DEFAULT_ASSETS
        bool "Flash Aset Default"
        depends on !USE_EMOTE_MESSAGE_STYLE
    config FLASH_CUSTOM_ASSETS
        bool "Flash Aset Kustom"
    config FLASH_EXPRESSION_ASSETS
        bool "Flash Aset Emote"
        depends on USE_EMOTE_MESSAGE_STYLE
endchoice

config CUSTOM_ASSETS_FILE
    depends on FLASH_CUSTOM_ASSETS
    string "File Aset Kustom"
    default "assets.bin"
    help
        File aset kustom yang akan di-flash.
        Dapat berupa file lokal relatif terhadap direktori proyek atau URL remote.

choice
    prompt "Bahasa Default"
    default LANGUAGE_ID_ID
    help
        Pilih bahasa tampilan dan audio lokal perangkat.
        Dukungan firmware ESP32 dibatasi ke Indonesia dan Inggris.
        Kemampuan multi-bahasa pada server tetap tidak berubah.

    config LANGUAGE_EN_US
        bool "Inggris"
    config LANGUAGE_ID_ID
        bool "Indonesia"
endchoice

