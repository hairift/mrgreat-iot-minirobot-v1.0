        bool "AIPI-Lite"
        depends on IDF_TARGET_ESP32S3
    config BOARD_TYPE_HU_087
        bool "HU-087"
        depends on IDF_TARGET_ESP32S3
endchoice

choice
    depends on BOARD_TYPE_LILYGO_T_DISPLAY_P4
    prompt "Pilih tipe layar"
    default SCREEN_TYPE_HI8561
        config SCREEN_TYPE_HI8561
            bool "HI8561"
        config SCREEN_TYPE_RM69A10
            bool "RM69A10"
endchoice

choice
    depends on BOARD_TYPE_LILYGO_T_DISPLAY_P4
    prompt "Pilih format warna layar"
    default SCREEN_PIXEL_FORMAT_RGB565
        config SCREEN_PIXEL_FORMAT_RGB565
            bool "RGB565"
        config SCREEN_PIXEL_FORMAT_RGB888
            bool "RGB888"
endchoice

choice ESP_S3_LCD_EV_Board_Version_TYPE
    depends on BOARD_TYPE_ESP_S3_LCD_EV_Board
    prompt "Tipe EV_BOARD"
    default ESP_S3_LCD_EV_Board_1p4
    config ESP_S3_LCD_EV_Board_1p4
        bool "ESP32_S3_LCD_EV_Board-MB_V1.4"
    config ESP_S3_LCD_EV_Board_1p5
        bool "ESP32_S3_LCD_EV_Board-MB_V1.5"
endchoice

choice DISPLAY_OLED_TYPE
    depends on BOARD_TYPE_BREAD_COMPACT_WIFI || BOARD_TYPE_BREAD_COMPACT_ML307 || BOARD_TYPE_BREAD_COMPACT_NT26 || BOARD_TYPE_BREAD_COMPACT_ESP32 || BOARD_TYPE_HU_087
    prompt "Tipe OLED"
    default OLED_SSD1306_128X32
    help
        Tipe Layar Monokrom OLED
    config OLED_SSD1306_128X32
        bool "SSD1306 128*32"
    config OLED_SSD1306_128X64
        bool "SSD1306 128*64"
    config OLED_SH1106_128X64
        bool "SH1106 128*64"
endchoice

choice DISPLAY_LCD_TYPE
    depends on BOARD_TYPE_BREAD_COMPACT_WIFI_LCD || BOARD_TYPE_BREAD_COMPACT_ESP32_LCD || BOARD_TYPE_CGC || BOARD_TYPE_BREAD_COMPACT_WIFI_CAM
    prompt "Tipe LCD"
    default LCD_ST7789_240X320
    help
        Tipe Layar LCD
    config LCD_ST7789_240X320
        bool "ST7789 240*320, IPS"
    config LCD_ST7789_240X320_NO_IPS
        bool "ST7789 240*320, Non-IPS"
    config LCD_ST7789_170X320
        bool "ST7789 170*320"
    config LCD_ST7789_172X320
        bool "ST7789 172*320"
    config LCD_ST7789_240X280
        bool "ST7789 240*280"
    config LCD_ST7789_240X240
        bool "ST7789 240*240"
    config LCD_ST7789_240X240_7PIN
        bool "ST7789 240*240, 7PIN"
    config LCD_ST7789_240X135
        bool "ST7789 240*135"
    config LCD_ST7735_128X160
        bool "ST7735 128*160"
    config LCD_ST7735_128X128
        bool "ST7735 128*128"
    config LCD_ST7796_320X480
        bool "ST7796 320*480 IPS"
    config LCD_ST7796_320X480_NO_IPS
        bool "ST7796 320*480, Non-IPS"
    config LCD_ILI9341_240X320
        bool "ILI9341 240*320"
    config LCD_ILI9341_240X320_NO_IPS
        bool "ILI9341 240*320, Non-IPS"
    config LCD_GC9A01_240X240
        bool "GC9A01 240*240 Lingkaran"
    config LCD_CUSTOM
        bool "LCD Kustom (Konfigurasi Parameter Layar Kustom)"
endchoice

choice DISPLAY_ESP32S3_KORVO2_V3
    depends on BOARD_TYPE_ESP_KORVO2_V3 || BOARD_TYPE_ESP_KORVO2_V3_RNDIS
    prompt "Tipe LCD ESP32S3_KORVO2_V3"
    default ESP32S3_KORVO2_V3_LCD_ST7789
    help
        Tipe Layar LCD
    config ESP32S3_KORVO2_V3_LCD_ST7789
        bool "ST7789 240*280"
    config ESP32S3_KORVO2_V3_LCD_ILI9341
        bool "ILI9341 240*320"
endchoice

choice DISPLAY_ESP32S3_AUDIO_BOARD
    depends on BOARD_TYPE_WAVESHARE_ESP32_S3_AUDIO_BOARD
    prompt "Tipe LCD ESP32S3_AUDIO_BOARD"
    default AUDIO_BOARD_LCD_JD9853
    help
        Tipe Layar LCD
    config AUDIO_BOARD_LCD_JD9853
        bool "JD9853 320*172"
    config AUDIO_BOARD_LCD_ST7789
        bool "ST7789 240*320"
endchoice

choice DISPLAY_ESP32S3_TOUCH_LCD_1_85C
    depends on BOARD_TYPE_WAVESHARE_ESP32_S3_TOUCH_LCD_1_85C
    prompt "Versi ESP32S3_TOUCH_LCD_1_85C"
    default VERSION_2_0 
    help
        Versi hardware
    config VERSION_1_0
        bool "versi 1.0"
    config VERSION_2_0
        bool "versi 2.0"
endchoice


choice DISPLAY_STYLE
    prompt "Pilih gaya tampilan"
    default USE_DEFAULT_MESSAGE_STYLE
    help
        Pilih gaya tampilan untuk perangkat Xiaozhi

    config USE_DEFAULT_MESSAGE_STYLE
        bool "Aktifkan gaya pesan default"

    config USE_WECHAT_MESSAGE_STYLE
        bool "Aktifkan Gaya Pesan WeChat"

    config USE_EMOTE_MESSAGE_STYLE
        bool "Gaya animasi emote"
        depends on BOARD_TYPE_ESP_BOX || BOARD_TYPE_ESP_BOX_3 \
            || BOARD_TYPE_ESP_VOCAT || BOARD_TYPE_LICHUANG_DEV_S3 \
            || BOARD_TYPE_ESP_SENSAIRSHUTTLE
endchoice

config USE_MULTILINE_CHAT_MESSAGE
    bool "Gunakan tampilan pesan obrolan multiline (mode default saja)"
    depends on USE_DEFAULT_MESSAGE_STYLE
    default n
    help
        Saat diaktifkan, area pesan obrolan dalam mode tampilan default menampilkan
        beberapa baris yang dibungkus yang tumbuh ke atas dari bagian bawah layar,
        dengan tinggi adaptif otomatis.
        Saat dinonaktifkan (default), label gulir horizontal satu baris
        ditampilkan di bagian bawah layar.

choice WAKE_WORD_TYPE
    prompt "Tipe Implementasi Wake Word"
    default USE_AFE_WAKE_WORD if (IDF_TARGET_ESP32S3 || IDF_TARGET_ESP32P4) && SPIRAM
    default WAKE_WORD_DISABLED
    help
        Pilih tipe implementasi wake word yang akan digunakan

    config WAKE_WORD_DISABLED
        bool "Nonaktif"
        help
            Nonaktifkan deteksi wake word

    config USE_ESP_WAKE_WORD
        bool "Model Wakenet tanpa AFE"
        depends on IDF_TARGET_ESP32C3 || IDF_TARGET_ESP32C5 || IDF_TARGET_ESP32C6 || (IDF_TARGET_ESP32 && SPIRAM)
        help
            Mendukung ESP32 C3、ESP32 C5 dan ESP32 C6, serta (ESP32 dengan PSRAM)

    config USE_AFE_WAKE_WORD
        bool "Model Wakenet dengan AFE"
        depends on (IDF_TARGET_ESP32S3 || IDF_TARGET_ESP32P4) && SPIRAM
        help
            Mendukung AEC jika tersedia, memerlukan ESP32 S3 dan PSRAM

    config USE_CUSTOM_WAKE_WORD
        bool "Model Multinet (Kata Bangun Kustom)"
        depends on (IDF_TARGET_ESP32S3 || IDF_TARGET_ESP32P4) && SPIRAM
        help
            Memerlukan ESP32 S3 dan PSRAM

endchoice

config CUSTOM_WAKE_WORD
    string "Kata Bangun Kustom"
    default "xiao tu dou"
    depends on USE_CUSTOM_WAKE_WORD
    help
        Kata Bangun Kustom, gunakan pinyin untuk Cina, dipisahkan dengan spasi

config CUSTOM_WAKE_WORD_DISPLAY
    string "Tampilan Kata Bangun Kustom"
    default "Xiaotudou"
    depends on USE_CUSTOM_WAKE_WORD
    help
        Sapaan yang dikirim ke server setelah deteksi wake word

config CUSTOM_WAKE_WORD_THRESHOLD
    int "Ambang Batas Kata Bangun Kustom (%)"
    default 20
    range 1 99
    depends on USE_CUSTOM_WAKE_WORD
    help
        Ambang Batas Kata Bangun Kustom, rentang 1-99, semakin kecil semakin sensitif, default 20

config SEND_WAKE_WORD_DATA
    bool "Kirim Data Wake Word"
    default y
    depends on USE_AFE_WAKE_WORD || USE_CUSTOM_WAKE_WORD
    help
        Kirim data wake word ke server sebagai pesan pertama percakapan dan tunggu respons

config WAKE_WORD_DETECTION_IN_LISTENING
    bool "Aktifkan Deteksi Wake Word dalam Mode Mendengarkan"
    default n
    depends on USE_AFE_WAKE_WORD || USE_CUSTOM_WAKE_WORD
    help
        Aktifkan deteksi wake word saat dalam mode mendengarkan.
        Saat diaktifkan, perangkat dapat mendeteksi wake word selama mendengarkan,
        yang memungkinkan interupsi percakapan saat ini.
        Saat dinonaktifkan (default), deteksi wake word dimatikan saat mendengarkan.

config USE_AUDIO_PROCESSOR
    bool "Aktifkan Pengurangan Noise Audio"
    default y
    depends on (IDF_TARGET_ESP32S3 || IDF_TARGET_ESP32P4) && SPIRAM
    help
        Memerlukan ESP32 S3 dan PSRAM

config USE_DEVICE_AEC
    bool "Aktifkan AEC Sisi Perangkat"
    default n
        depends on USE_AUDIO_PROCESSOR && (BOARD_TYPE_ESP_BOX_3 || BOARD_TYPE_ESP_BOX || BOARD_TYPE_ESP_BOX_LITE \
        || BOARD_TYPE_LICHUANG_DEV_S3 || BOARD_TYPE_ESP_KORVO2_V3 || BOARD_TYPE_WAVESHARE_ESP32_S3_TOUCH_AMOLED_1_75|| BOARD_TYPE_WAVESHARE_ESP32_S3_TOUCH_AMOLED_1_75C || BOARD_TYPE_WAVESHARE_ESP32_S3_TOUCH_LCD_1_83\
        || BOARD_TYPE_WAVESHARE_ESP32_S3_TOUCH_AMOLED_2_06 || BOARD_TYPE_WAVESHARE_ESP32_S3_TOUCH_LCD_4B || BOARD_TYPE_WAVESHARE_ESP32_P4_WIFI6_TOUCH_LCD_4B || BOARD_TYPE_WAVESHARE_ESP32_P4_WIFI6_TOUCH_LCD_4_3 \
        || BOARD_TYPE_WAVESHARE_ESP32_P4_WIFI6_TOUCH_LCD_7B \
        || BOARD_TYPE_WAVESHARE_ESP32_P4_WIFI6_TOUCH_LCD_3_4C || BOARD_TYPE_WAVESHARE_ESP32_P4_WIFI6_TOUCH_LCD_4C || BOARD_TYPE_ESP_S3_LCD_EV_Board_2 || BOARD_TYPE_YUNLIAO_S3 \
        || BOARD_TYPE_WAVESHARE_ESP32_P4_WIFI6_TOUCH_LCD_7 || BOARD_TYPE_WAVESHARE_ESP32_P4_WIFI6_TOUCH_LCD_8 || BOARD_TYPE_WAVESHARE_ESP32_P4_WIFI6_TOUCH_LCD_10_1 \
        || BOARD_TYPE_ESP_VOCAT || BOARD_TYPE_WAVESHARE_ESP32_S3_TOUCH_LCD_3_49 || BOARD_TYPE_WAVESHARE_ESP32_S3_RLCD_4_2 || BOARD_TYPE_ZHENGCHEN_CAM || BOARD_TYPE_ZHENGCHEN_CAM_ML307 \
        || BOARD_TYPE_WAVESHARE_ESP32_S3_TOUCH_LCD_4_3C)
    help
        Untuk bekerja dengan baik, AEC sisi perangkat memerlukan jalur referensi output yang bersih dari sinyal speaker dan isolasi akustik fisik antara mikrofon dan speaker.

config USE_SERVER_AEC
    bool "Aktifkan AEC Sisi Server (Tidak Stabil)"
    default n
    depends on USE_AUDIO_PROCESSOR
    help
        Untuk bekerja dengan baik, AEC sisi server memerlukan dukungan server

config USE_AUDIO_DEBUGGER
    bool "Aktifkan Debugger Audio"
    default n
    help
        Aktifkan debugger audio, kirim data audio melalui UDP ke mesin host

menu "Metode Konfigurasi WiFi"
    help
        Pemilihan Metode Konfigurasi WiFi
    config USE_HOTSPOT_WIFI_PROVISIONING
        bool "Hotspot"
        default y
        help
            Gunakan WiFi Hotspot untuk mengirimkan data konfigurasi WiFi
    config USE_ACOUSTIC_WIFI_PROVISIONING
        bool "Akustik"
        help
            Gunakan sinyal audio untuk mengirimkan data konfigurasi WiFi

    config USE_ESP_BLUFI_WIFI_PROVISIONING
        bool "Esp Blufi"
        help
            Gunakan protokol esp blufi untuk mengirimkan data konfigurasi WiFi
        select BT_ENABLED
        select BT_BLE_42_FEATURES_SUPPORTED
        select BT_BLE_BLUFI_ENABLE
        select MBEDTLS_DHM_C
endmenu

config AUDIO_DEBUG_UDP_SERVER
    string "Alamat Server UDP Debug Audio"
    default "192.168.2.100:8000"
    depends on USE_AUDIO_DEBUGGER
    help
        Alamat server UDP, format: IP:PORT, digunakan untuk menerima data debugging audio

config RECEIVE_CUSTOM_MESSAGE
    bool "Aktifkan Penerimaan Pesan Kustom"
    default n
    help
        Aktifkan penerimaan pesan kustom, izinkan perangkat menerima pesan kustom dari server (lebih baik melalui protokol MQTT)

menu "Konfigurasi Kamera"
    depends on !IDF_TARGET_ESP32

    comment "Peringatan: Silakan baca teks bantuan sebelum memodifikasi pengaturan ini."

    config XIAOZHI_CAMERA_ALLOW_JPEG_INPUT
        bool "Izinkan Input JPEG"
        default n
        help
            Izinkan format Input JPEG untuk kamera.

            Opsi ini mungkin perlu diaktifkan saat menggunakan kamera USB.

            Saat ini tidak didukung saat digunakan bersamaan dengan XIAOZHI_ENABLE_ROTATE_CAMERA_IMAGE.

    config XIAOZHI_ENABLE_HARDWARE_JPEG_ENCODER
        bool "Aktifkan Encoder JPEG Hardware"
        default y
        depends on SOC_JPEG_ENCODE_SUPPORTED
        help
            Gunakan encoder JPEG hardware di ESP32-P4 untuk mengenkode gambar ke JPEG.
            Lihat https://docs.espressif.com/projects/esp-idf/en/stable/esp32p4/api-reference/peripherals/jpeg.html untuk detail lebih lanjut.

    config XIAOZHI_ENABLE_HARDWARE_JPEG_DECODER
        bool "Aktifkan Decoder JPEG Hardware"
        default n
        depends on SOC_JPEG_DECODE_SUPPORTED && XIAOZHI_CAMERA_ALLOW_JPEG_INPUT
        help
            Gunakan decoder JPEG hardware di ESP32-P4 untuk mendekode JPEG ke gambar.
            Lihat https://docs.espressif.com/projects/esp-idf/en/stable/esp32p4/api-reference/peripherals/jpeg.html untuk detail lebih lanjut.

    config XIAOZHI_ENABLE_CAMERA_DEBUG_MODE
        bool "Aktifkan Mode Debug Kamera"
        default n
        help
            Aktifkan mode debug kamera, cetak informasi debug kamera ke konsol.
            Hanya berfungsi pada board yang mendukung kamera.

    config XIAOZHI_ENABLE_CAMERA_ENDIANNESS_SWAP
        bool "Aktifkan penggantian endianness buffer kamera perangkat lunak"
        default n
        depends on !CAMERA_SENSOR_SWAP_PIXEL_BYTE_ORDER
        help
            Opsi ini memperlakukan buffer kamera sebagai array uint16_t[] dan melakukan byte-swapping (konversi endianness) pada setiap elemen.

            Hanya boleh dimodifikasi oleh insinyur integrasi board pengembangan.

            **Penggunaan yang salah dapat mengakibatkan warna gambar yang tidak benar!**

            PERHATIAN: Jika opsi CAMERA_SENSOR_SWAP_PIXEL_BYTE_ORDER tersedia untuk sensor Anda, silakan gunakan itu saja.

    menuconfig XIAOZHI_ENABLE_ROTATE_CAMERA_IMAGE
        bool "Aktifkan Rotasi Gambar Kamera"
        default n
        depends on !XIAOZHI_CAMERA_ALLOW_JPEG_INPUT
        help
            Aktifkan rotasi gambar kamera, putar gambar kamera ke orientasi yang benar.
            - Di ESP32-P4, rotasi ditangani oleh hardware PPA.
            - Di chip lain, rotasi dilakukan di perangkat lunak dengan biaya performa.
            - Untuk rotasi 180°, gunakan HFlip + VFlip, bukan opsi ini.

            Saat ini tidak didukung saat digunakan bersamaan dengan XIAOZHI_CAMERA_ALLOW_JPEG_INPUT.

    if XIAOZHI_ENABLE_ROTATE_CAMERA_IMAGE
        choice XIAOZHI_CAMERA_IMAGE_ROTATION_ANGLE
            prompt "Sudut Rotasi Gambar Kamera (searah jarum jam)"
            default XIAOZHI_CAMERA_IMAGE_ROTATION_ANGLE_90
            help
                Sudut rotasi gambar kamera.
            config XIAOZHI_CAMERA_IMAGE_ROTATION_ANGLE_90
                bool "90°"
            config XIAOZHI_CAMERA_IMAGE_ROTATION_ANGLE_270
                bool "270°"
            comment "Untuk rotasi 180°, gunakan HFlip + VFlip, bukan opsi ini"
        endchoice
    endif
endmenu

menu "KONFIGURASI_TAIJIPAI_S3"
    depends on BOARD_TYPE_TAIJI_PI_S3
    choice I2S_TYPE_TAIJIPI_S3
        prompt "Tipe I2S taiji-pi-S3"
        default TAIJIPAI_I2S_TYPE_STD
        help
            Pemilihan Tipe I2S
        config TAIJIPAI_I2S_TYPE_STD
            bool "Tipe I2S STD"
        config TAIJIPAI_I2S_TYPE_PDM
            bool "Tipe I2S PDM"
    endchoice

    config I2S_USE_2SLOT
    bool "Aktifkan I2S 2 Slot"
    default y
    help
        Aktifkan dual channel
endmenu

endmenu
